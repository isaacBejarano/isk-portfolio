{
  "name": "portfolio",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.7.0",
  "engines": {
    "node": ">= 24.9.0"
  },
  "scripts": {
    "start": "npm-run-all check ng:serve",
    "build": "npm-run-all check ng:build",
    "ng:serve": "ng serve",
    "ng:build": "ng build",
    "watch": "ng build --watch --configuration development",
    "check": "npx @biomejs/biome check --write",
    "lint": "npx @biomejs/biome lint --write",
    "format": "npx @biomejs/biome format --write",
    "test": "ng test",
    "test:coverage": "ng test --coverage",
    "e2e": "ng e2e",
    "e2e:report": "npx playwright show-report",
    "fire:login": "firebase login",
    "fire:reauth": "firebase login --reauth",
    "fire:init": "firebase init hosting",
    "fire:emulators": "firebase init emulators",
    "fire:start": "firebase emulators:start",
    "fire:deploy": "firebase deploy --only hosting"
  },
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "rxjs": "^7.4.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.0",
    "@angular/cli": "^21.1.0",
    "@angular/compiler-cli": "^21.1.0",
    "@biomejs/biome": "2.3.14",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "firebase-tools": "^15.5.1",
    "npm-run-all": "^4.1.5",
    "playwright-ng-schematics": "^21.0.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3"
  }
}
